# Copy to .env and fill in values. Do not commit .env.

# Optional: Fernet key for encrypting profile/conversation data in SQLite.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KID_AGENT_DB_KEY=

# Optional: Pixabay API key for "show me a picture" image search. Get a free key at https://pixabay.com/api/docs/
# If unset, image requests are answered by the LLM without fetching a real image.
# PIXABAY_API_KEY=

# Optional: NASA API key for Space Mode (astronomy picture of the day). Get a free key at https://api.nasa.gov/
# If unset, DEMO_KEY is used (lower rate limits: 30/hr, 50/day).
# NASA_API_KEY=

# Ollama model; must support tool calling (e.g. qwen2.5, llama3.1). See backend/README.md.
# MODEL_NAME=qwen2.5

# Optional: MCP servers (JSON array). Alternatively use mcp_servers.json in the backend directory.
# Example (weather): [{"id":"weather","command":"npx","args":["-y","@philschmid/weather-mcp"]}]
# Example (NASA): [{"id":"nasa","command":"npx","args":["-y","@programcomputer/nasa-mcp-server"],"env":{"NASA_API_KEY":"..."}}]
# Default: mcp_servers.json enables the weather MCP server (requires Node.js/npx).
# MCP_SERVERS=
